---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => {
  return data.pubDate <= new Date();
});

posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog — Plenum AI Systems"
  description="Insights on AI-powered growth systems, lead follow-up, and revenue recovery for home service businesses."
  canonical="https://plenumaisystems.com/blog">

<Nav />

<section class="page-hero">
  <div class="container">
    <div class="label">Blog</div>
    <h1>Insights & Strategies</h1>
    <p>Practical insights on AI-powered growth systems, lead follow-up, and revenue recovery for home service businesses.</p>
  </div>
</section>

<section>
  <div class="container">
    <div style="display:flex;flex-direction:column;gap:24px;margin-top:40px;">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="card" style="display:block;text-decoration:none;">
          <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:8px;">
            <span style="font-family:'JetBrains Mono',monospace;font-size:0.75rem;color:var(--text3);">{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </div>
          <h3 style="margin-bottom:8px;color:var(--text);">{post.data.title}</h3>
          <p style="color:var(--text2);font-size:0.9rem;">{post.data.description}</p>
          <span style="display:inline-block;margin-top:12px;color:var(--blue);font-size:0.85rem;font-weight:600;">Read more →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="container">
    <h2>Want insights delivered?</h2>
    <p>We publish new strategies and case studies regularly. Check back often.</p>
    <a href="/contact" class="btn btn-primary">→ Get in Touch</a>
  </div>
</section>

<Footer />

</BaseLayout>
