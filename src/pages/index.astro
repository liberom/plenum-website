<script>
  // FAQ accordion
  document.querySelectorAll('.faq-item h3').forEach(h => {
    h.addEventListener('click', () => h.parentElement.classList.toggle('open'));
  });

  // Service accordion with artifact switching
  function toggleAccordion(el) {
    document.querySelectorAll('.accordion-item').forEach(item => {
      item.classList.remove('active');
    });
    el.classList.add('active');
    const num = el.querySelector('.accordion-number').textContent.trim();
    document.querySelectorAll('.artifact').forEach(a => {
      a.style.display = 'none';
      a.classList.remove('active');
    });
    const artifact = document.querySelector(`.artifact[data-artifact="${num}"]`);
    if (artifact) {
      artifact.style.display = 'block';
      artifact.classList.add('active');
    }
  }
</script>

